# KiCAD Prism Frontend Configuration
# Copy this file to .env and customize for your environment

# ===========================================
# Google OAuth Configuration
# ===========================================
# Get your Client ID from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
#
# This should match the GOOGLE_CLIENT_ID in the backend configuration
# Leave empty if authentication is disabled on the backend
VITE_GOOGLE_CLIENT_ID=

# ===========================================
# Dev Server Host Allowlist
# ===========================================
# The hostname from VITE_APP_URL is automatically trusted by the Vite dev
# server so you never need to edit vite.config.ts.
# Set this to the public URL where the frontend is accessed (same value as
# APP_URL in backend/.env).
VITE_APP_URL=http://localhost:5173

# Optional: comma-separated extra hostnames to trust, e.g. a reverse-proxy
# hostname or an additional test domain.
#   VITE_ALLOWED_HOSTS=staging.example.com,preview.example.com
VITE_ALLOWED_HOSTS=

# ===========================================
# Dev Server API Proxy
# ===========================================
# Port the backend is running on (used by the Vite dev-server proxy).
# Must match BACKEND_PORT in backend/.env. Only needed for local development;
# Docker uses nginx which reads BACKEND_PORT directly.
VITE_BACKEND_PORT=8000

# Full backend API URL override — use instead of VITE_BACKEND_PORT when the
# backend is on a different host (e.g. VITE_API_URL=http://192.168.1.10:8000).
# When set, this takes precedence over VITE_BACKEND_PORT.
VITE_API_URL=
