# KiCAD Prism Backend Configuration
# Copy this file to .env and customize for your environment

# ===========================================
# Google OAuth + RBAC Configuration
# ===========================================
# Friendly workspace display name shown on the login page
WORKSPACE_NAME=KiCAD Prism

# Get your Client ID from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Set false to disable authentication entirely
AUTH_ENABLED=true

# Optional allowlist filters. Leave empty to rely only on RBAC role assignments.
ALLOWED_USERS_STR=
ALLOWED_DOMAINS_STR=

# Primary admin account - created automatically on first startup.
# Set ADMIN_EMAIL to your address and ADMIN_PASSWORD to a strong password.
# Changing these values after the account is created will NOT update the password
# (use the forgot-password flow instead).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# Public-facing URL where users access the frontend (used in verification/reset emails).
# When accessing from other machines on your network, change localhost to your IP or domain.
# Example: APP_URL=http://192.168.1.100:5173  or  APP_URL=https://prism.yourcompany.com
APP_URL=http://localhost:5173

# ===========================================
# Network / Server Binding
# ===========================================
# Host the backend uvicorn server listens on.
#   127.0.0.1  → localhost only (default, most secure)
#   0.0.0.0    → all network interfaces (required for LAN / remote access)
# Note: Docker already binds to 0.0.0.0; this setting only affects direct
# local runs (python -m app.main).
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Vite dev-server API proxy target (frontend only).  Leave blank to use the
# default http://127.0.0.1:8000.  Only needed if you are running the backend
# on a different host or port during development.
VITE_API_URL=

# Additional bootstrap admin emails (comma-separated, optional)
# These accounts receive permanent admin access alongside ADMIN_EMAIL.
BOOTSTRAP_ADMIN_USERS_STR=

# Role store file path (optional override; defaults to <projects_root>/.rbac_roles.json)
ROLE_STORE_PATH=

# Session signing secret (required when AUTH_ENABLED=true and DEV_MODE=false)
SESSION_SECRET=change-me-to-a-long-random-secret

# Session lifetime in hours
SESSION_TTL_HOURS=12

# Set to true only when serving over HTTPS
SESSION_COOKIE_SECURE=false

# ===========================================
# Development Settings
# ===========================================
# Keep false for normal authentication flow
DEV_MODE=false

# === GitHub Organization-owned OAuth App (recommended) ===
# Create this app here: https://github.com/organizations/YOUR_ORG/settings/apps/new
# (Organization → Settings → Developer settings → OAuth Apps → New OAuth App)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ORG_LOGIN=yourcompanyorg          # ← must match the organization that owns the OAuth App
GITHUB_SCOPES=repo,read:org              # gives read access to org repositories

# Encryption key for storing GitHub access tokens securely
TOKEN_ENCRYPTION_KEY=

# ===========================================
# Email / SMTP (for verification + password reset)
# ===========================================
SMTP_HOST=smtp.yourmailserver.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=prism@yourcompany.com
# Set true to use STARTTLS when connecting to the SMTP server
SMTP_TLS=true

# ===========================================
# Email domain whitelist for auto-approval
# ===========================================
# Comma-separated list of email domains automatically approved on login
ALLOWED_EMAIL_DOMAINS_STR=yourcompany.com,example.com

# ===========================================
# Optional Git Access
# ===========================================
GITHUB_TOKEN=
